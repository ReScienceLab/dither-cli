{
  "name": "@resciencelab/dither-cli",
  "version": "0.1.0",
  "description": "Agent-native image dithering CLI — powered by dithermark's algorithms",
  "type": "module",
  "bin": {
    "dither": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f));fs.chmodSync(f,0o755)\"",
    "dev": "tsc --watch",
    "test": "node dist/index.js --version"
  },
  "keywords": [
    "dither",
    "dithering",
    "pixel-art",
    "image-processing",
    "cli",
    "dithermark"
  ],
  "author": "ReScienceLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ReScienceLab/dither-cli"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1",
    "sharp": "^0.33.5"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
